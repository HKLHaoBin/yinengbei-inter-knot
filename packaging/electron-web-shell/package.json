{
  "name": "inter-knot-web-shell",
  "version": "1.0.0",
  "private": true,
  "description": "Windows shell packaging for the Inter-Knot web build",
  "main": "main.js",
  "scripts": {
    "dist:win": "electron-builder --win portable --x64"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "productName": "Inter Knot",
    "appId": "cn.tiwat.interknot.webshell",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "web/**/*"
    ],
    "portable": {
      "artifactName": "inter_knot_web_windows_portable.exe"
    }
  }
}
